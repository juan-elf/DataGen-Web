# ── LLM (OpenRouter) ───────────────────────────────────────────────────────
# Required — used by the agent + guardrail classifier
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key-here

# Main agent model (premium — e.g. anthropic/claude-sonnet-4-5, openai/gpt-4o)
AGENT_MODEL=google/gemma-4-31b-it:free

# Guardrail classifier model (fast/cheap — only needs to reply ALLOW or BLOCK)
GUARDRAIL_MODEL=openai/gpt-oss-120b:free
# Override with a separate API key if using a different provider:
# GUARDRAIL_API_KEY=sk-or-separate-key-if-needed

# Optional — enables web search via Tavily (https://tavily.com, free tier 1,000/month)
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# ── Database (Supabase Postgres) ──────────────────────────────────────────
# Required — read-only role, used by every agent tool call (execute_sql, profiler, ...)
# GRANT SELECT ON ALL TABLES IN SCHEMA <workspace> TO this role; enforce via
# role privileges, not just app-layer checks — see core/database.py docstring.
DATABASE_URL=postgresql://agent_reader:password@host:5432/postgres

# Optional — write-enabled role, used only by ingest/ (CSV/Excel upload) and
# the workspace registry/TTL sweep. Falls back to DATABASE_URL if unset
# (fine for local dev; use a separate least-privilege role in production).
WRITE_DATABASE_URL=postgresql://agent_writer:password@host:5432/postgres

# Idle workspace schemas older than this are dropped by db/cleanup.py
WORKSPACE_TTL_DAYS=7

# ── Workspace identity ────────────────────────────────────────────────────
# Required in production — signs the anonymous workspace cookie (db/context.py).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Set to false only for local HTTP (non-HTTPS) development
COOKIE_SECURE=true

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_ORIGIN=http://localhost:3000

# ── Admin ──────────────────────────────────────────────────────────────────
# Bearer token for POST /admin/cleanup (the keep-alive/TTL-sweep cron job hits
# this — see .github/workflows/keepalive.yml). Leave unset to disable the route.
CLEANUP_TOKEN=
